# Copy to `.env` and fill in. Read automatically by `docker compose`.
# `.env` is gitignored; never commit real keys.

# --- AI circadian scoring (Circadiem) ---------------------------------------
# Your OpenAI API key (must start with sk-). The workbench forwards it to
# Circadiem as a per-request bearer token; neither service stores it.
OPENAI_API_KEY=sk-...

# Where the workbench reaches Circadiem. The default points at the bundled
# `circadiem` compose service by name; override to use an external instance.
CIRCADIEM_BASE_URL=http://circadiem:5174

# Image for the optional local Circadiem service (used with `--profile ai`).
# Set this to wherever Circadiem is published, or switch the compose service to
# `build:` a local checkout instead.
CIRCADIEM_IMAGE=ghcr.io/dhuzard/circadiem:latest
